{
  "name": "finance-dashboard-api",
  "version": "1.0.0",
  "description": "Finance Dashboard Backend – Node.js/Express/MongoDB REST API with JWT auth and RBAC",
  "main": "src/server.js",
  "scripts": {
    "start": "nodemon server.js",
    "dev": "nodemon --watch src/server.js",
